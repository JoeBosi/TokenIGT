{
  "name": "igt-token",
  "version": "1.0.0",
  "description": "IGE Token - Advanced ERC-20 Token with UUPS Upgradeability",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy/deploy_local.ts",
    "deploy:amoy": "hardhat run scripts/deploy/deploy_amoy.ts --network amoy",
    "deploy:polygon": "hardhat run scripts/deploy/deploy_polygon.ts --network polygon",
    "upgrade:local": "hardhat run scripts/upgrade/upgrade_local.ts",
    "upgrade:amoy": "hardhat run scripts/upgrade/upgrade_amoy.ts --network amoy",
    "upgrade:polygon": "hardhat run scripts/upgrade/upgrade_polygon.ts --network polygon",
    "verify": "hardhat run scripts/verify.ts",
    "roles:grant": "hardhat run scripts/roles/grant_roles.ts",
    "roles:revoke": "hardhat run scripts/roles/revoke_roles.ts",
    "roles:list": "hardhat run scripts/roles/list_roles.ts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-foundry": "^3.0.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/hardhat-upgrades": "^3.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.6",
    "chai": "^4.4.1",
    "ethers": "^6.9.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^1.0.9",
    "solidity-coverage": "^0.8.5",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.6.1",
    "@openzeppelin/contracts-upgradeable": "5.6.1",
    "dotenv": "^16.3.1"
  }
}
