{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node", "mocha", "chai"]
  },
  "include": ["scripts/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist", "artifacts", "cache"]
}
